#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

for candidate in \
  "$REPO_ROOT/skills/dev-discipline/scripts/committer" \
  "$REPO_ROOT/.agents/skills/dev-discipline/scripts/committer" \
  "$HOME/.agents/skills/dev-discipline/scripts/committer"; do
  if [ -f "$candidate" ]; then
    exec "$candidate" "$@"
  fi
done

echo "Could not find dev-discipline committer implementation."
echo "Expected one of:"
echo "  skills/dev-discipline/scripts/committer"
echo "  .agents/skills/dev-discipline/scripts/committer"
echo "  ~/.agents/skills/dev-discipline/scripts/committer"
exit 1
